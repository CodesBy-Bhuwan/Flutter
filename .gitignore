# ------------------------------------------------------------------------------
# Package lock file – IMPORTANT DECISION
# ------------------------------------------------------------------------------

# For applications: COMMIT pubspec.lock to ensure reproducible builds.
# For libraries: IGNORE pubspec.lock to allow dependency flexibility.

# By default, we include it – you can uncomment the next line if you want to ignore it.
pubspec.lock